{
  "name": "mlang-support",
  "displayName": "MLang Support",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "mlang",
        "aliases": [
          "MLang",
          "mlang"
        ],
        "extensions": [
          ".mlang"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icon.png",
          "dark": "./icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "mlang",
        "scopeName": "source.mlang",
        "path": "./syntaxes/mlang.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "mlang",
        "path": "./snippets/snippets.code-snippets"
      }
    ]
  }
}
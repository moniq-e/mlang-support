{
  "name": "mlang-support",
  "displayName": "MLang Support",
  "main": "./extension.js",
  "description": "",
  "publisher": "Monique",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.106.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "mlang",
        "aliases": [
          "MLang",
          "mlang"
        ],
        "extensions": [
          ".mlang",
          ".mlang.old"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icon.png",
          "dark": "./icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "mlang",
        "scopeName": "source.mlang",
        "path": "./syntaxes/mlang.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "mlang",
        "path": "./snippets/snippets.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "mlang.runFile",
        "title": "Execute MLang file",
        "icon": "$(play)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "mlang.runFile",
          "group": "navigation",
          "when": "resourceLangId == mlang"
        }
      ]
    }
  }
}